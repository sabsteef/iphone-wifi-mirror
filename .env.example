# Copy this file to `.env` (or paste the lines into your shell rc) and
# fill in the values for YOUR install. None of these are secret in a
# security sense, but the WDA bundle ID must match what you actually
# signed in Xcode or the app can't find the runner on your iPhone.

# ─── Required ────────────────────────────────────────────────────────────────

# The exact bundle ID of the signed WebDriverAgentRunner app on your
# iPhone. This must match the "Bundle Identifier" you set in Xcode when
# building WebDriverAgent, PLUS the ".xctrunner" suffix Xcode appends
# to the runner target.
#
# Example: if you signed the WDA target with `com.jdoe.WebDriverAgentRunner`,
# then WDA_BUNDLE_ID=com.jdoe.WebDriverAgentRunner.xctrunner
export WDA_BUNDLE_ID="com.example.WebDriverAgentRunner.xctrunner"

# ─── Optional tuning ─────────────────────────────────────────────────────────

# Tap alignment. Empirically 0.95 works well on iPhone 17 Pro Max +
# iOS 27 where WebDriverAgent drifts taps ~5% too low as y grows.
# Lower (e.g. 0.93) if taps still land below where you clicked.
# Higher (e.g. 0.98) if taps land above where you clicked.
# export TAP_Y_SCALE=0.95
# export TAP_X_SCALE=1.0
